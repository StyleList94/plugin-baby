    "node": ">=20"
  },
  "peerDependencies": {
    "vite": ">=8.0.0"
  },
  "devDependencies": {
    "@plugin-baby/eslint-config": "workspace:*",
    "@plugin-baby/typescript-config": "workspace:*",
    "@types/node": "^24.12.4",
