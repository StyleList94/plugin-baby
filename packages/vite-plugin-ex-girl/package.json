{
  "name": "@stylelish/vite-plugin-ex-girl",
  "version": "0.0.0",
  "description": "Build Chrome extensions (MV3) with Vite",
  "author": "StyleList94",
  "license": "MIT",
  "homepage": "https://github.com/StyleList94/plugin-baby/tree/main/packages/vite-plugin-ex-girl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StyleList94/plugin-baby.git",
    "directory": "packages/vite-plugin-ex-girl"
  },
  "bugs": {
    "url": "https://github.com/StyleList94/plugin-baby/issues"
  },
  "scripts": {
